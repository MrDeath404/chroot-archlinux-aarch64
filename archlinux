#!/bin/bash

archPath="/data/local/distro/arch"
tmpPath="/data/local/distro/tmp"
termuxBin="/data/data/com.termux/files/usr/bin"
scriptSleep="1"
messageSleep="0.2"

arch_logo() {
    printf "\e[36m                  ▄
                 ▄█▄
                ▄███▄
               ▄█████▄
              ▄███████▄
             ▄ ▀▀██████▄
            ▄██▄▄ ▀█████▄
           ▄█████████████▄
          ▄███████████████▄
         ▄█████████████████▄
        ▄███████████████████▄
       ▄█████████▀▀▀▀████████▄
      ▄████████▀      ▀███████▄
     ▄█████████        ████▀▀██▄
    ▄██████████        █████▄▄▄
   ▄██████████▀        ▀█████████▄
  ▄██████▀▀▀              ▀▀██████▄
 ▄███▀▀                       ▀▀███▄
▄▀▀                               ▀▀▄\e[0m\n"
}

warning() {
    sleep "$messageSleep"
    printf "[\e[33mWARNING\e[0m] - %s\n" "$1"
}

success() {
    sleep "$messageSleep"
    printf "[\e[32mSUCCESS\e[0m] - %s\n" "$1"
}

info() {
    sleep "$messageSleep"
    printf "[\e[34mINFO\e[0m] - %s\n" "$1"
}

error() {
    sleep "$messageSleep"
    printf "[\e[31mERROR\e[0m] - %s\n" "$1" >&2
}

is_root() {
    if su -c "exit" > /dev/null 2>&1; then
        return 0
    fi
    return 1
}

get_arg_no_check() {
    local arg="$1"
    local argName="$2"

    if [[ -z "$arg" || "$arg" =~ ^-- ]]; then
        echo ""
        return
    fi
    echo "$arg"
}

get_arg() {
    local arg="$1"
    local argName="$2"

    if [[ -z "$arg" || "$arg" =~ ^-- ]]; then
        error "Missing value for \"$argName\"" 
        exit 1
    fi
    echo "$arg"
}

setup_env() {
    info "Installing needed packages"
    {
        pkg update
        pkg upgrade -y
        pkg install root-repo -y
        pkg install busybox -y
    } || error "Failed to install some packages"
    success "Packages were successfully installed"
    if is_root; then
        info "Superuser permision was granted by root provicer" 
    else 
        error "Can't not acceess superuser permission"
        info "Root your device with magisk or kernelsu based root provider and grant superuser permission"
        exit 1
    fi
}

download_zip() {
    local zipPath="$tmpPath/ArchLinuxARM-aarch64-latest.tar.gz"
    info "Downloading ArchLinux Generic ZIP for aarch64(arm64)"
    if su -c curl -L --progress-bar -o "$zipPath" "http://os.archlinuxarm.org/os/ArchLinuxARM-aarch64-latest.tar.gz"; then
        success "ArchLinux Generic ZIP was downloaded successfully"
        info "File is located at $zipPath"
    else 
        error "Unknown error while downloading ArchLinux Generic ZIP"
        su -c rm -rf "$zipPath"
        exit 1
    fi
}

redownload_zip() {
    su -c rm -rf "$tmpPath"
    su -c mkdir -p "$tmpPath"
    download_zip
}

install_arch() {
    zipPath="$1"

    if [ -z "$zipPath" ]; then
        zipPath="$tmpPath/ArchLinuxARM-aarch64-latest.tar.gz"
    fi
    if su -c test -d "$archPath"; then
        warning "ArchLinux is already install on this device. If you want you can use \"reinstall\" option"
        exit 0
    else
        info "Creating ArchLinux container at $archPath"
        su -c mkdir -p "$archPath"
    fi
    if ! su -c test -d "$tmpPath"; then
        su -c mkdir -p "$tmpPath"
    fi
    if su -c test -f "$zipPath"; then
        info "ArchLinux Generic ZIP was found at $tmpPath"
        info "If you want to redownload it use \"redownload\" option"
    else
        warning "ArchLinux zip was not found"
        download_zip
    fi
    info "Unpacking ArchLinux Generic ZIP at $archPath"
    if sudo "$termuxBin/tar" \
        --extract \
        --gzip \
        --file="$zipPath" \
        --no-same-owner \
        --no-same-permissions \
        --directory="$archPath" ; then
        success "Archive was successfully unpacked to $archPath"
    else
        error "Failed to unpack archive"
        su -c rm -rf "$archPath"
        exit 1
    fi
    info "Performing additional steps to set up ArchLinux"
    {
        su -c mkdir -p "$archPath/media/sdcard"
        cat << "EOF" | su -c "tee \"$tmpPath/resolv.conf\" >/dev/null"
nameserver 1.1.1.1
nameserver 1.0.0.1
nameserver 2606:4700:4700::1111
nameserver 2606:4700:4700::1001
nameserver 8.8.8.8
nameserver 8.8.4.4
nameserver 2001:4860:4860::8888
nameserver 2001:4860:4860::8844
EOF
        su -c mv -vf "$tmpPath/resolv.conf" "$archPath/etc"
    } || {
        error "Failed to perform additional steps"
        exit 1
    }
    success "ArchLinux was successfully installed"
    warning "Use \"archlinux login setup\" to login frist time"
}

is_arch_booted() {
    {
        sudo "$termuxBin/busybox" mountpoint -q "$archPath/proc" &&
        sudo "$termuxBin/busybox" mountpoint -q "$archPath/sys" &&
        sudo "$termuxBin/busybox" mountpoint -q "$archPath/dev" &&
        sudo "$termuxBin/busybox" mountpoint -q "$archPath/dev/pts"
    } > /dev/null 2>&1
}

boot_arch() {
    arch_logo
    if is_arch_booted; then
        info "ArchLinux is already running"
        exit 0
    fi
    info "Booting ArchLinux"
    {
        sudo "$termuxBin/busybox" mount -o remount,dev,suid /data
        sudo mount -o bind /dev "$archPath/dev"
        sudo "$termuxBin/busybox" mount -t proc proc "$archPath/proc"
        sudo "$termuxBin/busybox" mount -t sysfs sysfs "$archPath/sys"
        sudo "$termuxBin/busybox" mount -t devpts devpts "$archPath/dev/pts"
        sudo "$termuxBin/busybox" mount -o bind /sdcard "$archPath/media/sdcard"
        sudo "$termuxBin/busybox" mount -t tmpfs /cache "$archPath/var/cache"
    } || {
        error "Failed to boot ArchLinux"
        exit 1
    }
    success "ArchLinux booted and it's ready to use"
}

setup_root() {
    info "Setting up root account and updating your ArchLinux"
    if sudo "$termuxBin/busybox" chroot "$archPath" su - $user -c \
    "(
        groupadd -g 3003 aid_inet &&
        groupadd wheel &&
        usermod -G 3003 -a root &&
        sed -i "s/^# \*%wheel ALL=\(ALL:ALL\) ALL/%wheel ALL=\(ALL:ALL\) ALL/" /etc/sudoers &&
        sed -i "s/^#\\\(en_US\.UTF-8 UTF-8\\\)/\\1/" /etc/locale.gen &&
        echo "LANG=en_US.UTF-8" > /etc/locale.conf &&
        locale-gen &&
        pacman-key --init &&
        pacman-key --populate archlinuxarm &&
        pacman-key --refresh-keys &&
        pacman -Syu --noconfirm &&
        pacman -S --noconfirm sudo &&
        exit 0
    ) || exit 1"; then
        success "ArchLinux is now ready to use. You can login with \"archlinux login\""
    else
        error "Failed to setup ArchLinux enviroment"
        exit 1
    fi
    warning "Please use \"archlinux login add username\" to add user"
    info "To delete user you have to use userdel inside your ArchLinux"
}

login_arch() {
    if ! is_arch_booted; then
        boot_arch
    fi
    user="$1"
    if [ -z "$user" ]; then
        user="root"
    fi
    if [ "$user" == "setup" ]; then
        setup_root
    fi
    info "Logging in as $user"
    sudo "$termuxBin/busybox" chroot "$archPath" su - $user
}

shutdown_arch() {
    if !is_arch_booted; then
        warning "ArchLinux is already shutdown"
        exit 0
    fi
    arch_logo
    info "Shutting down ArchLinux"
    {
        sudo "$termuxBin/busybox" umount -l "$archPath/media/sdcard"
        sudo "$termuxBin/busybox" umount -l "$archPath/dev/pts"
        sudo "$termuxBin/busybox" umount -l "$archPath/proc"
        sudo "$termuxBin/busybox" umount -l "$archPath/sys"
        sudo "$termuxBin/busybox" umount -l "$archPath/dev"
    } || {
        error "Failed to shutdown ArchLinux"
        exit 1
    }
    success "ArchLinux has been shutdown successfully"
}

reboot_arch() {
    shutdown_arch
    sleep "$scriptSleep"
    clear  
    boot_arch
}

remove_arch() {
    info "Uninstalling ArchLinux"
    if su -c rm -rf "$archPath"; then
        success "ArchLinux has been uninstalled"
    else 
        error "Failed to uninstall ArchLinux"
        exit 1
    fi
}

reinstall_arch() {
    remove_arch
    sleep "$scriptSleep"
    clear  
    install_arch
}

clean_zip() {
    info "Removing ArchLinux Generic ZIP from $tmpPath"
    if su -c rm -rf "$tmpPath"; then
        success "ArchLinux Generic ZIP was successfully removed"
    else
        error "Failed to remove ArchLinux Generic ZIP"
        exit 1
    fi
}

help() {
    info "Usage: archlinux {install [zip_path] | remove | reinstall | login <user> | boot | reboot | shutdown | redownload | clean | help}"
}

if [ "$#" -eq 0 ]; then
    help
fi

while [ "$#" -gt 0 ]; do
    case "$1" in
        setup)
            clear
            setup_env
            shift
            ;;
        install)
            clear
            zipPath=$(get_arg_no_check "$2" "$1")
            install_arch $zipPath
            shift
            if [ -n $zipPath ]; then
                shift
            fi
            ;;
        remove)
            clear
            remove_arch
            shift
            ;;
        reinstall)
            clear
            reinstall_arch
            shift
            ;;
        login)
            clear
            user=$(get_arg_no_check "$2" "$1")
            login_arch $user
            shift
            if [ -n $zipPath ]; then
                shift
            fi
            ;;
        boot)
            clear
            boot_arch
            shift
            ;;
        shutdown)
            clear
            shutdown_arch
            shift
            ;;
        reboot)
            clear
            reboot_arch
            shift
            ;;
        redownload)
            clear
            redownload_zip
            shift
            ;;
        clean)
            clear
            clean_zip
            shift
            ;;
        help)
            clear
            help
            exit 0
            ;;
        *)
            clear
            warning "Unknown option: $1"
            help
            exit 1
            ;;
    esac
done