#!/bin/bash

tmpPath="/data/local/distro/tmp"
archPath="/data/local/distro/arch"
scriptSleep="5s"

warning() {
    printf "[\e[33mWARNING\e[0m] - %s\n" "$1"
}

success() {
    printf "[\e[32mSUCCESS\e[0m] - %s\n" "$1"
}

info() {
    printf "[\e[34mINFO\e[0m] - %s\n" "$1"
}

error() {
    printf "[\e[31mERROR\e[0m] - %s\n" "$1" >&2
}

is_root() {
    if su -c "exit" > /dev/null 2>&1; then
        return 0
    fi
    return 1
}

get_arg_no_check() {
    local arg="$1"
    local argName="$2"

    if [[ -z "$arg" || "$arg" =~ ^-- ]]; then
        echo ""
        return
    fi
    echo "$arg"
}

get_arg() {
    local arg="$1"
    local argName="$2"

    if [[ -z "$arg" || "$arg" =~ ^-- ]]; then
        error "Missing value for \"$argName\"" 
        exit 1
    fi
    echo "$arg"
}

setup_env() {
    info "Installing needed packages"
    pkg update
    pkg upgrade -y
    pkg install root-repo
    pkg install busybox
    if is_root; then
        info "Superuser permision was granted by root provicer" 
    else 
        error "Can't not acceess superuser permission"
        info "Root your device with magisk or kernelsu based root provider and grant superuser permission"
        exit 1
    fi
    success "Packages were successfully installed"
}

download_zip() {
    local zipPath="$tmpPath/ArchLinuxARM-aarch64-latest.tar.gz"
    warning "ArchLinux zip was not found"
    info "Downloading ArchLinux Generic for aarch64(arm64)"
    if sudo curl -L --progress-bar -o "$zipPath" "http://os.archlinuxarm.org/os/ArchLinuxARM-aarch64-latest.tar.gz"; then
        success "ArchLinux Generic ZIP was downloaded successfully"
        info "File is located at $zipPath"
    else 
        error "Unknown error while downloading ArchLinux Generic ZIP"
        su -c rm -rf "$zipPath"
        exit 1
    fi
}

redownload_zip() {
    su -c rm -rf "$tmpPath"
    su -c mkdir -p "$tmpPath"
    echo $(download_zip)
}

install_arch() {
    zipPath="$1"

    if [ -z "$zipPath" ]; then
        zipPath="$tmpPath/ArchLinuxARM-aarch64-latest.tar.gz"
    fi
    if su -c test -d "$archPath"; then
        warning "ArchLinux is already install on this device. If you want you can use \"reinstall\" option"
        exit 0
    else
        info "Creating ArchLinux container at $archPath"
        su -c mkdir -p "$archPath"
    fi
    if ! su -c test -d "$tmpPath"; then
        su -c mkdir -p "$tmpPath"
    fi
    if su -c test -f "$zipPath"; then
        info "ArchLinux Generic ZIP was found at $tmpPath"
        info "If you want to redownload it use \"redownload\" option"
    else
        download_zip
    fi
    info "Unpacking ArchLinux Generic ZIP at $archPath"
    if sudo tar --extract --verbose --file=\"$zipPath\" \
        --numeric-owner --directory=\"$archPath\" \
        --checkpoint=1 --checkpoint-action=progress ; then
        success "Archive was successfully unpacked to $archPath"
    else
        error "Failed to unpack archive. It may have been corrupted during download."
        su -c rm -rf "$zipPath"
        su -c rm -rf "$archPath"
        exit 1
    fi
    info "Performing additional steps to set up Arch Linux"
    {
        su -c mkdir -p "$archPath/media/sdcard"
        cat << "EOF" | su -c "tee '$archPath/etc/resolv.conf' >/dev/null"
nameserver 1.1.1.1
nameserver 1.0.0.1
nameserver 2606:4700:4700::1111
nameserver 2606:4700:4700::1001
nameserver 8.8.8.8
nameserver 8.8.4.4
nameserver 2001:4860:4860::8888
nameserver 2001:4860:4860::8844
EOF
        cat << "EOF" | su -c "tee '$archPath/root/reset-pacman.sh' >/dev/null"
#!/bin/sh
pacman-key --init
pacman-key --populate archlinuxarm
EOF
        su -c chmod +x "$archPath/root/reset-pacman.sh"
    } || {
        error "Failed to perform additional steps"
        exit 1
    }
    success "ArchLinux was successfully installed"
    echo -e "\033[36m
                   -\`
                  .o+\`
                 \`ooo/
                \`+oooo:
               \`+oooooo:
               -+oooooo+:
             \`/:-:++oooo+:
            \`/++++/+++++++:
           \`/++++++++++++++:
          \`/+++ooooooooooooo/\`
         ./ooosssso++osssssso+\`
        .oossssso-\`\`\`\`/ossssss+\`
       -osssssso.      :ssssssso.
      :osssssss/        osssso+++.
     /ossssssss/        +ssssooo/-
   \`/ossssso+/:-        -:/+osssso+-
  \`+sso+:-\`                 \`.-/+oso:
 \`++:.                           \`-/+/
 .\`                                 \`
\033[0m"
    warning "Use \"archlinux login\" to login frist time"
}

is_arch_booted() {
    sudo busybox mountpoint -q "$archPath/proc" &&
    sudo busybox mountpoint -q "$archPath/sys" &&
    sudo busybox mountpoint -q "$archPath/dev" &&
    sudo busybox mountpoint -q "$archPath/dev/pts"
}

boot_arch() {
    if is_arch_booted; then
        info "ArchLinux is already running"
        exit 0
    fi
    info "Booting ArchLinux"
    {
        sudo busybox mount -o remount,dev,suid /data
        sudo busybox mount -o bind /dev "$archPath/dev"
        sudo busybox mount -t proc proc "$archPath/proc"
        sudo busybox mount -t sysfs sysfs "$archPath/sys"
        sudo busybox mount -t devpts devpts "$archPath/dev/pts"
        sudo busybox mount -o bind /sdcard "$archPath/media/sdcard"
    } || {
        error "Failed to boot ArchLinux"
        exit 1
    }
echo -e "\033[36m
                   -\`
                  .o+\`
                 \`ooo/
                \`+oooo:
               \`+oooooo:
               -+oooooo+:
             \`/:-:++oooo+:
            \`/++++/+++++++:
           \`/++++++++++++++:
          \`/+++ooooooooooooo/\`
         ./ooosssso++osssssso+\`
        .oossssso-\`\`\`\`/ossssss+\`
       -osssssso.      :ssssssso.
      :osssssss/        osssso+++.
     /ossssssss/        +ssssooo/-
   \`/ossssso+/:-        -:/+osssso+-
  \`+sso+:-\`                 \`.-/+oso:
 \`++:.                           \`-/+/
 .\`                                 \`
\033[0m"
    success "ArchLinux booted and it's ready to use"
}

login_arch() {
    if !is_arch_booted; then
        boot_arch
    fi
    user="$1"
    if [ -z "$user" ]; then
        user="root"
    fi
    info "Logging in as $user"
    sudo busybox chroot "$archPath" /bin/su - $user
}

shutdown_arch() {
    info "Shutting down ArchLinux"
    {
        sudo busybox umount -l "$archPath/media/sdcard"
        sudo busybox umount -l "$archPath/dev/pts"
        sudo busybox umount -l "$archPath/proc"
        sudo busybox umount -l "$archPath/sys"
        sudo busybox umount -l "$archPath/dev"
    } || {
        error "Failed to shutdown ArchLinux"
        exit 1
    }
    success "ArchLinux has been shut down successfully"
}

reboot_arch() {
    shutdown_arch
    sleep "$(scriptSleep)"
    clear
    boot_arch
}

remove_arch() {
    info "Uninstalling ArchLinux"
    if su -c rm -rf "$archPath"; then
        success "ArchLinux has been uninstalled"
    else 
        error "Failed to uninstall ArchLinux"
        exit 1
    fi
}

reinstall_arch() {
    remove_arch
    sleep "$(scriptSleep)"
    clear
    install_arch
}

clean_zip() {
    info "Removing ArchLinux Generic ZIP"
    if su -c rm -rf "$tmpPath"; then
        success "ArchLinux Generic ZIP was successfully removed"
    else
        error "Failed to remove ArchLinux Generic ZIP"
        exit 1
    fi
}

help() {
    info "Usage: archlinux {install [zip_path] | remove | reinstall | login <user> | boot | reboot | shutdown | redownload | clean | help}"
}

if [ "$#" -eq 0 ]; then
    help
fi

while [ "$#" -gt 0 ]; do
    case "$1" in
        setup)
            clear
            setup_env
            shift
            ;;
        install)
            clear
            zipPath=$(get_arg_no_check "$2" "$1")
            install_arch $zipPath
            shift
            if [ -n $zipPath ]; then
                shift
            fi
            ;;
        remove)
            clear
            remove_arch
            shift
            ;;
        reinstall)
            clear
            reinstall_arch
            shift
            ;;
        login)
            clear
            user=$(get_arg_no_check "$2" "$1")
            login_arch $user
            shift
            if [ -n $zipPath ]; then
                shift
            fi
            ;;
        boot)
            clear
            boot_arch
            shift
            ;;
        shutdown)
            clear
            shutdown_arch
            shift
            ;;
        reboot)
            clear
            reboot_arch
            shift
            ;;
        redownload)
            clear
            redownload_zip
            shift
            ;;
        clean)
            clear
            clean_zip
            shift
            ;;
        help)
            clear
            help
            exit 0
            ;;
        *)
            clear
            warning "Unknown option: $1"
            help
            exit 1
            ;;
    esac
done